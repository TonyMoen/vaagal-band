# Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# Sanity CMS Configuration
# Get your project ID from https://www.sanity.io/manage
VITE_SANITY_PROJECT_ID=your-project-id
VITE_SANITY_DATASET=production

# Web3Forms Contact Form API Key
# Get your key from https://web3forms.com/
VITE_WEB3FORMS_KEY=your-access-key

# Shopify Storefront API Configuration
# Get your access token from Shopify Admin > Apps > Develop apps
VITE_SHOPIFY_STOREFRONT_TOKEN=your-storefront-access-token
VITE_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
